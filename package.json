{
  "name": "blazedocs",
  "version": "3.0.1",
  "description": "Agent-first CLI for PDF → Markdown. JSON everywhere, --raw, structured errors. Humans get the polish too.",
  "type": "module",
  "bin": {
    "blazedocs": "dist/bin/blazedocs.cjs"
  },
  "files": [
    "dist",
    "docs/assets",
    "scripts",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "preinstall": "node scripts/preinstall.cjs",
    "build": "tsc && node scripts/postbuild.mjs",
    "dev": "tsc --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "blazedocs",
    "pdf",
    "pdf-to-markdown",
    "markdown",
    "ocr",
    "cli",
    "document-processing",
    "obsidian",
    "rag",
    "agent-skills",
    "agent-first"
  ],
  "author": "BlazeDocs",
  "homepage": "https://blazedocs.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyle93afc/blazedocs-cli.git"
  },
  "bugs": {
    "url": "https://github.com/kyle93afc/blazedocs-cli/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
